#!/usr/bin/env bash
set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Paths - resolve symlinks to get the real script location
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
SCAFFOLDS_DIR="$(dirname "$SCRIPT_DIR")/scaffolds"
SHARED_DIR="$SCAFFOLDS_DIR/shared"

# Load config for PROJECT_DIR
CONFIG_FILE="$HOME/.config/scaffold/config"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
fi
PROJECT_DIR="${PROJECT_DIR:-$HOME/code}"

# Helper functions
print_header() {
    echo -e "\n${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}  $1${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
}

print_step() {
    echo -e "${GREEN}→${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

# Validate project name (alphanumeric and hyphens only)
validate_project_name() {
    local name="$1"

    # Must be lowercase alphanumeric with hyphens, start/end with alphanumeric
    if [[ ${#name} -eq 1 ]]; then
        if [[ ! "$name" =~ ^[a-z0-9]$ ]]; then
            print_error "Project name must be lowercase alphanumeric"
            exit 1
        fi
    elif [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*[a-z0-9]$ ]]; then
        print_error "Project name must be lowercase alphanumeric with hyphens"
        print_error "Must start and end with a letter or number"
        exit 1
    fi

    if [[ ${#name} -gt 64 ]]; then
        print_error "Project name must be 64 characters or less"
        exit 1
    fi
}

# Validate project path is within PROJECT_DIR
validate_project_path() {
    local project_path="$1"

    # Resolve to absolute path and check it's within PROJECT_DIR
    local resolved_parent
    resolved_parent="$(cd "$(dirname "$project_path")" 2>/dev/null && pwd)" || {
        print_error "Invalid project path"
        exit 1
    }

    if [[ "$resolved_parent" != "$PROJECT_DIR" ]]; then
        print_error "Project must be created in $PROJECT_DIR"
        exit 1
    fi
}

# Prompt for input with default
prompt() {
    local prompt_text="$1"
    local default="${2:-}"
    local result

    if [ -n "$default" ]; then
        read -p "$prompt_text [$default]: " result
        echo "${result:-$default}"
    else
        read -p "$prompt_text: " result
        echo "$result"
    fi
}

# Prompt for yes/no
confirm() {
    local prompt_text="$1"
    local default="${2:-y}"
    local result

    if [ "$default" = "y" ]; then
        read -p "$prompt_text [Y/n]: " result
        result="${result:-y}"
    else
        read -p "$prompt_text [y/N]: " result
        result="${result:-n}"
    fi

    [[ "$result" =~ ^[Yy] ]]
}

# Select from options
select_option() {
    local prompt_text="$1"
    shift
    local options=("$@")

    # Print menu to stderr so it displays when output is captured
    echo -e "\n${BLUE}$prompt_text${NC}" >&2
    for i in "${!options[@]}"; do
        echo "  $((i+1))) ${options[$i]}" >&2
    done

    local selection
    while true; do
        read -p "Select [1-${#options[@]}]: " selection
        if [[ "$selection" =~ ^[0-9]+$ ]] && [ "$selection" -ge 1 ] && [ "$selection" -le "${#options[@]}" ]; then
            echo "${options[$((selection-1))]}"
            return
        fi
        echo "Invalid selection" >&2
    done
}

# Check for existing project
check_existing_project() {
    local project_path="$1"

    if [ -d "$project_path" ]; then
        if [ -f "$project_path/.claude/CLAUDE.md" ]; then
            # Check if it's a discovery project
            if grep -q "Discovery Phase" "$project_path/.claude/CLAUDE.md" 2>/dev/null; then
                return 1  # Discovery project exists
            fi
        fi
        return 2  # Non-discovery project exists
    fi
    return 0  # No project
}

# Scaffold Next.js project
scaffold_nextjs() {
    local project_name="$1"
    local use_supabase="${2:-false}"
    local no_security="${3:-false}"
    local TARGET_DIR="$PROJECT_DIR/$project_name"

    # Safety trap
    trap '[[ -n "${TARGET_DIR:-}" ]] && [[ "$TARGET_DIR" != "/" ]] && rm -rf "$TARGET_DIR"' ERR INT TERM

    # Validate target doesn't exist
    if [ -d "$TARGET_DIR" ]; then
        print_error "Directory $TARGET_DIR already exists"
        exit 1
    fi

    # 1. Copy base template (Better Auth + Drizzle + Neon)
    print_step "Creating Next.js project..."
    cp -r "$SCAFFOLDS_DIR/nextjs/template" "$TARGET_DIR"

    # 2. --supabase: apply Supabase overlay and remove composable-specific files
    if [ "$use_supabase" = "true" ]; then
        print_step "Applying Supabase variant..."
        cp -r "$SCAFFOLDS_DIR/nextjs/supabase/"* "$TARGET_DIR/"
        rm -rf "$TARGET_DIR/src/lib/auth"
        rm -rf "$TARGET_DIR/src/lib/db"
        rm -rf "$TARGET_DIR/src/app/api/auth"
        rm -f "$TARGET_DIR/drizzle.config.ts"
    fi

    # 3. Claude configs
    print_step "Setting up Claude Code..."
    mkdir -p "$TARGET_DIR/.claude/hooks" "$TARGET_DIR/.claude/commands" "$TARGET_DIR/.claude/skills" "$TARGET_DIR/.claude/presets"
    cp -r "$SCAFFOLDS_DIR/nextjs/claude/"* "$TARGET_DIR/.claude/"
    # Move CLAUDE.md to project root
    mv "$TARGET_DIR/.claude/CLAUDE.md" "$TARGET_DIR/CLAUDE.md"
    find "$TARGET_DIR/.claude/hooks" -name "*.sh" -exec chmod +x {} + 2>/dev/null

    # 4. DevOps
    print_step "Setting up DevOps..."
    cp "$SCAFFOLDS_DIR/nextjs/devops/vercel.json" "$TARGET_DIR/"
    cp "$SCAFFOLDS_DIR/nextjs/devops/coderabbit.yaml" "$TARGET_DIR/.coderabbit.yaml"
    mkdir -p "$TARGET_DIR/.github/workflows"
    cp "$SCAFFOLDS_DIR/nextjs/devops/.github/workflows/"*.yml "$TARGET_DIR/.github/workflows/"
    if [ -f "$SCAFFOLDS_DIR/nextjs/devops/PULL_REQUEST_TEMPLATE.md" ]; then
        cp "$SCAFFOLDS_DIR/nextjs/devops/PULL_REQUEST_TEMPLATE.md" "$TARGET_DIR/.github/"
    fi

    # 5. Security scanning
    if [ "$no_security" != "true" ] && [ -d "$SHARED_DIR/security" ]; then
        print_step "Adding security scanning workflow..."
        cp "$SHARED_DIR/security/.github/workflows/security.yml" "$TARGET_DIR/.github/workflows/"
    fi

    # 7. String replace (allowlisted extensions only)
    print_step "Configuring project name..."
    find "$TARGET_DIR" -type f \( \
        -name "*.ts" -o -name "*.tsx" -o -name "*.json" -o \
        -name "*.md" -o -name "*.yaml" -o -name "*.yml" -o \
        -name "*.css" -o -name ".env.example" \
    \) -exec perl -pi -e "s/{{PROJECT_NAME}}/$project_name/g" {} +

    # 8. Install & Git Hooks
    print_step "Initializing git repository..."
    cd "$TARGET_DIR"
    git init

    print_step "Setting up git hooks..."
    npx husky init

    print_step "Installing dependencies with pnpm..."
    pnpm install

    # 9. Success — remove trap
    trap - ERR INT TERM
    print_success "Next.js project created at $TARGET_DIR"
}

# Keep scaffold_t3 as alias for backward compatibility
scaffold_t3() {
    scaffold_nextjs "$@"
}

# Scaffold Laravel project
scaffold_laravel() {
    local project_name="$1"
    local no_security="${2:-false}"
    local project_path="$PROJECT_DIR/$project_name"

    print_step "Creating Laravel project..."

    cd "$PROJECT_DIR"
    composer create-project laravel/laravel "$project_name"

    cd "$project_path"

    # Install Breeze with React + Inertia
    print_step "Installing Laravel Breeze with React..."
    composer require laravel/breeze --dev
    php artisan breeze:install react --typescript --ssr

    # Install UI kit packages (npm)
    print_step "Installing UI kit packages..."
    npm install lucide-react class-variance-authority clsx tailwind-merge sonner

    # Install testing packages
    print_step "Installing testing packages..."
    composer require pestphp/pest pestphp/pest-plugin-laravel --dev
    composer require laravel/dusk --dev
    composer require larastan/larastan --dev

    # Copy Claude setup
    print_step "Setting up Claude Code..."
    mkdir -p .claude/commands
    cp "$SCAFFOLDS_DIR/laravel/CLAUDE.md" ./CLAUDE.md
    perl -pi -e "s/{{PROJECT_NAME}}/$project_name/g" ./CLAUDE.md
    cp "$SCAFFOLDS_DIR/laravel/settings.json" .claude/settings.json
    cp "$SCAFFOLDS_DIR/laravel/mcp.json" .claude/mcp.json
    cp "$SCAFFOLDS_DIR/laravel/claudeignore" .claudeignore

    # Copy devops
    print_step "Setting up DevOps..."
    mkdir -p .github/workflows
    cp "$SCAFFOLDS_DIR/laravel/devops/coderabbit.yaml" .coderabbit.yaml
    cp "$SCAFFOLDS_DIR/laravel/devops/workflows/"*.yml .github/workflows/
    cp "$SCAFFOLDS_DIR/laravel/devops/PULL_REQUEST_TEMPLATE.md" .github/

    # Security scanning
    if [ "$no_security" != "true" ] && [ -d "$SHARED_DIR/security" ]; then
        print_step "Adding security scanning workflow..."
        cp "$SHARED_DIR/security/.github/workflows/security.yml" "$project_path/.github/workflows/"
    fi

    print_success "Laravel project created!"
}

# Scaffold Discovery project
scaffold_discovery() {
    local project_name="$1"
    local project_path="$PROJECT_DIR/$project_name"

    print_step "Creating Discovery project..."

    mkdir -p "$project_path/.claude/commands"
    mkdir -p "$project_path/requirements"

    # Copy Claude setup
    cp "$SCAFFOLDS_DIR/discovery/CLAUDE.md" "$project_path/.claude/CLAUDE.md"
    perl -pi -e "s/{{PROJECT_NAME}}/$project_name/g" "$project_path/.claude/CLAUDE.md"

    # Also create a symlink at the root for convenience
    ln -sf .claude/CLAUDE.md "$project_path/CLAUDE.md"

    # Copy requirements commands
    cp "$SCAFFOLDS_DIR/discovery/commands/"*.md "$project_path/.claude/commands/"

    # Create .gitkeep
    touch "$project_path/requirements/.current-requirement"

    print_success "Discovery project created!"
}

# Upgrade discovery project to a stack
upgrade_project() {
    local project_name="$1"
    local project_path="$PROJECT_DIR/$project_name"

    if [ ! -d "$project_path" ]; then
        print_error "Project $project_name does not exist"
        exit 1
    fi

    if ! grep -q "Discovery Phase" "$project_path/.claude/CLAUDE.md" 2>/dev/null; then
        print_error "$project_name is not a Discovery project"
        exit 1
    fi

    print_header "Upgrading $project_name"

    local stack
    stack=$(select_option "Select stack:" "Next.js (Better Auth + Drizzle + Neon + tRPC + Tailwind)" "Next.js (Supabase)" "Laravel")

    # Backup the ENTIRE project, not just requirements
    print_step "Backing up existing project..."
    local temp_backup="/tmp/project-backup-$$"
    cp -r "$project_path" "$temp_backup"

    # Set up trap to restore on any failure
    trap 'print_error "Upgrade failed! Restoring original project..."; rm -rf "$project_path"; cp -r "$temp_backup" "$project_path"; rm -rf "$temp_backup"; print_success "Original project restored."; exit 1' ERR

    # Remove old project
    rm -rf "$project_path"

    # Create new project
    case "$stack" in
        "Next.js (Better Auth + Drizzle + Neon + tRPC + Tailwind)")
            scaffold_nextjs "$project_name" "false"
            ;;
        "Next.js (Supabase)")
            scaffold_nextjs "$project_name" "true"
            ;;
        "Laravel")
            scaffold_laravel "$project_name"
            ;;
    esac

    # Clear the trap now that scaffold succeeded
    trap - ERR

    # Restore requirements from backup
    if [ -d "$temp_backup/requirements" ]; then
        print_step "Restoring requirements folder..."
        cp -r "$temp_backup/requirements" "$project_path/requirements"
    fi

    # Cleanup backup
    rm -rf "$temp_backup"

    print_success "Project upgraded!"
}

# Initialize git and optionally create GitHub repo
init_git() {
    local project_name="$1"
    local project_path="$PROJECT_DIR/$project_name"

    cd "$project_path"

    if [ ! -d .git ]; then
        print_step "Initializing git repository..."
        git init
        git add .
        git commit -m "feat: initial scaffold

Created with create-project scaffold tool"
    fi

    local github_user
    github_user=$(gh api user -q .login 2>/dev/null) || {
        print_warning "Could not get GitHub user. Skipping remote setup."
        return
    }

    local repo_url="https://github.com/$github_user/$project_name"

    # Check if repo already exists on GitHub
    if gh repo view "$github_user/$project_name" &>/dev/null; then
        if confirm "GitHub repo exists. Push to $repo_url?"; then
            print_step "Pushing to existing repository..."
            git remote add origin "$repo_url.git" 2>/dev/null || git remote set-url origin "$repo_url.git"
            git branch -M main
            git push -u origin main --force-with-lease
            print_success "Pushed to: $repo_url"
        fi
    elif confirm "Create private GitHub repository?"; then
        print_step "Creating GitHub repository..."
        gh repo create "$project_name" --private --source=. --push
        print_success "GitHub repository created: $repo_url"
    fi
}

# Provision cloud services via Stripe Projects
provision_services() {
    local project_name="$1"
    local use_supabase="${2:-false}"
    local target_dir="$PROJECT_DIR/$project_name"

    # Require interactive terminal
    if [[ ! -t 0 ]]; then
        print_warning "--provision requires an interactive terminal. Skipping."
        return 0
    fi

    # Check stripe CLI
    if ! command -v stripe &>/dev/null; then
        print_warning "Stripe CLI not installed. Skipping provisioning."
        print_warning "Install: brew install stripe/stripe-cli/stripe && stripe plugin install projects"
        return 0
    fi

    # Auth + plugin check via catalog (side-effect-free)
    if ! stripe projects catalog >/dev/null 2>&1; then
        print_warning "Stripe Projects unavailable or not logged in."
        print_warning "Run: stripe login && stripe plugin install projects"
        return 0
    fi

    print_header "Provision Cloud Services"
    echo -e "${YELLOW}Note: This provisions real cloud accounts. Some services may incur costs.${NC}\n"

    # Build service list based on scaffold type
    local services=()
    local display_names=()
    local defaults=()

    if [ "$use_supabase" = "true" ]; then
        services=("supabase/project" "vercel/project" "sentry/project" "posthog/analytics")
        display_names=("Supabase (database + auth + storage)" "Vercel (hosting)" "Sentry (error tracking)" "PostHog (analytics)")
    else
        services=("neon/postgres" "vercel/project" "sentry/project" "posthog/analytics")
        display_names=("Neon (serverless Postgres)" "Vercel (hosting)" "Sentry (error tracking)" "PostHog (analytics)")
    fi
    defaults=("y" "y" "n" "n")

    # Interactive per-service confirmation
    local selected=()
    for i in "${!services[@]}"; do
        if confirm "  ${display_names[$i]}" "${defaults[$i]}"; then
            selected+=("${services[$i]}")
        fi
    done

    if [ "${#selected[@]}" -eq 0 ]; then
        print_step "No services selected. Skipping provisioning."
        return 0
    fi

    # Initialize Stripe Projects
    pushd "$target_dir" >/dev/null || return 1
    trap 'popd >/dev/null 2>&1 || true' RETURN

    print_step "Initializing Stripe Projects..."
    if ! stripe projects init "$project_name" -y; then
        print_warning "stripe projects init failed. Run manually: stripe projects init $project_name"
        return 0
    fi

    # Add each selected service
    local succeeded=()
    local failed=()
    for service in "${selected[@]}"; do
        print_step "Provisioning $service..."
        if stripe projects add "$service" -y --accept-tos; then
            succeeded+=("$service")
            print_success "$service provisioned"
        else
            failed+=("$service")
            print_warning "Failed to provision $service"
        fi
    done

    # Report failures
    if [ "${#failed[@]}" -gt 0 ]; then
        echo ""
        print_warning "Failed services (add manually):"
        for service in "${failed[@]}"; do
            echo "  stripe projects add $service"
        done
    fi

    # Sync credentials if any services succeeded
    if [ "${#succeeded[@]}" -gt 0 ]; then
        # Back up existing .env
        if [ -f .env ]; then
            cp .env ".env.backup.$(date +%Y%m%d%H%M%S)"
        fi

        print_step "Syncing credentials to .env..."
        if stripe projects env -y 2>/dev/null; then
            print_success "Credentials synced to .env"
        else
            print_warning "Failed to sync credentials. Run manually: stripe projects env"
        fi

        # Generate local-only env vars that Stripe Projects won't provide
        if [ "$use_supabase" != "true" ]; then
            # Ensure trailing newline before appending
            [ -f .env ] && [ -n "$(tail -c 1 .env 2>/dev/null)" ] && echo "" >> .env

            if ! grep -q '^BETTER_AUTH_SECRET=' .env 2>/dev/null; then
                if command -v openssl &>/dev/null; then
                    printf 'BETTER_AUTH_SECRET=%s\n' "$(openssl rand -base64 32)" >> .env
                else
                    print_warning "openssl not found. Skipping BETTER_AUTH_SECRET generation."
                fi
            fi
            if ! grep -q '^BETTER_AUTH_URL=' .env 2>/dev/null; then
                printf 'BETTER_AUTH_URL=http://localhost:3000\n' >> .env
            fi
        fi

        # Validate required env vars are present
        local required_envs=()
        if [ "$use_supabase" = "true" ]; then
            required_envs=("NEXT_PUBLIC_SUPABASE_URL" "NEXT_PUBLIC_SUPABASE_ANON_KEY")
        else
            required_envs=("DATABASE_URL" "BETTER_AUTH_SECRET" "BETTER_AUTH_URL")
        fi

        local missing=()
        for key in "${required_envs[@]}"; do
            if ! grep -Eq "^${key}=.+" .env 2>/dev/null; then
                missing+=("$key")
            fi
        done

        if [ "${#missing[@]}" -gt 0 ]; then
            echo ""
            print_warning "Missing env vars (set manually in .env):"
            for key in "${missing[@]}"; do
                echo "  $key"
            done
        fi
    else
        print_warning "No services provisioned. Skipping credential sync."
    fi

    echo ""
}

# Main function
main() {
    print_header "Create Project"

    local project_name=""
    local project_type=""
    local upgrade_mode=false
    local supabase=false
    local provision=false
    local no_security=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --type=*)
                project_type="${1#*=}"
                shift
                ;;
            --supabase)
                supabase=true
                shift
                ;;
            --composable)
                print_warning "Composable is now the default. The --composable flag is no longer needed." >&2
                shift
                ;;
            --provision)
                provision=true
                shift
                ;;
            --no-security)
                no_security=true
                shift
                ;;
            --upgrade)
                upgrade_mode=true
                shift
                ;;
            -*)
                print_error "Unknown option: $1"
                exit 1
                ;;
            *)
                project_name="$1"
                shift
                ;;
        esac
    done

    # Get project name if not provided
    if [ -z "$project_name" ]; then
        project_name=$(prompt "Project name")
    fi

    # Validate project name
    if [ -z "$project_name" ]; then
        print_error "Project name is required"
        exit 1
    fi

    validate_project_name "$project_name"

    local project_path="$PROJECT_DIR/$project_name"
    validate_project_path "$project_path"

    # Handle upgrade mode
    if $upgrade_mode; then
        upgrade_project "$project_name"
        init_git "$project_name"
        echo -e "\n${GREEN}Done!${NC} cd ~/code/$project_name"
        exit 0
    fi

    # Check for existing project
    check_existing_project "$project_path"
    local existing_status=$?

    if [ $existing_status -eq 1 ]; then
        if confirm "Discovery project exists. Upgrade to a stack?"; then
            upgrade_project "$project_name"
            init_git "$project_name"
            echo -e "\n${GREEN}Done!${NC} cd ~/code/$project_name"
            exit 0
        else
            print_error "Project already exists"
            exit 1
        fi
    elif [ $existing_status -eq 2 ]; then
        print_error "Project $project_name already exists and is not a Discovery project"
        exit 1
    fi

    # Get project type if not provided
    if [ -z "$project_type" ]; then
        project_type=$(select_option "Select project type:" "Next.js (Better Auth + Drizzle + Neon + tRPC + Tailwind)" "Laravel" "Discovery")
    fi

    # Security scanning prompt (default yes, skip for Discovery and non-TTY)
    if [ "$no_security" != "true" ]; then
        case "$project_type" in
            discovery|"Discovery") ;;
            *)
                if [ -t 0 ]; then
                    if ! confirm "Add security scanning (Semgrep + Trivy + Gitleaks)?" "y"; then
                        no_security=true
                    fi
                fi
                ;;
        esac
    fi

    # Scaffold based on type
    local is_nextjs=false
    case "$project_type" in
        nextjs|t3|"T3"|"T3 (Next.js)"|"Next.js (Better Auth + Drizzle + Neon + tRPC + Tailwind)")
            is_nextjs=true
            scaffold_nextjs "$project_name" "$supabase" "$no_security"
            ;;
        "Next.js (Supabase)"|"Next.js (Supabase + tRPC + Tailwind)")
            is_nextjs=true
            scaffold_nextjs "$project_name" "true" "$no_security"
            ;;
        laravel|"Laravel")
            scaffold_laravel "$project_name" "$no_security"
            ;;
        discovery|"Discovery")
            scaffold_discovery "$project_name"
            ;;
        *)
            print_error "Unknown project type: $project_type"
            exit 1
            ;;
    esac

    # Provision cloud services (Next.js only)
    if $provision && $is_nextjs; then
        provision_services "$project_name" "$supabase"
    elif $provision; then
        print_warning "--provision is currently only supported for Next.js projects."
    fi

    # Git setup
    init_git "$project_name"

    echo -e "\n${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  Project created successfully!${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "\n  ${CYAN}cd ~/code/$project_name${NC}\n"
}

main "$@"
